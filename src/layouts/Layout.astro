---
import "@/scss/main.scss";
import "@/scss/layout.scss";
import "@/tailwind.css";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    noindex?: boolean;
}

const {
    title = "Mind of Tay | Frontend Developer and Digital Designer",
    description = "Portfolio website of Tay, a frontend developer and digital designer showcasing recent projects, UI work, and creative development.",
    image = "/search-music-v2.svg",
    noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL("https://dontewhite.com");
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const imageUrl = new URL(image, site).toString();

const personJsonLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Tay",
    url: canonicalUrl,
    jobTitle: "Frontend Developer and Digital Designer",
    sameAs: [
        "https://github.com/dwhite02",
        "https://www.linkedin.com/in/dontewhite/",
    ],
};
---

<!doctype html>
<html lang="en" data-theme="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <!-- No-flash theme init: reads localStorage before any paint -->
        <script is:inline>
            (function () {
                var saved = localStorage.getItem("theme");
                if (saved === "light" || saved === "dark") {
                    document.documentElement.setAttribute("data-theme", saved);
                }
            })();
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@100;300;400;500;700;900&family=Roboto:wght@100;300;400;500;700;900&family=Passion+One:wght@700;900&display=swap"
        />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="portfolio, frontend developer, UI developer, digital designer, Chicago, web development, Vue, Astro"
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#F59E0B" />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/svg+xml" href="/vite.svg" />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={imageUrl} />
        <meta property="og:site_name" content="Mind of Tay" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={imageUrl} />

        {noindex && <meta name="robots" content="noindex, nofollow" />}

        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(personJsonLd)}
        />

        <!-- Spline viewer web component (lazy, only used in Contact) -->
        <script is:inline>
            (function () {
                var s = document.createElement("script");
                s.type = "module";
                s.src =
                    "https://unpkg.com/@splinetool/viewer@1.9.82/build/spline-viewer.js";
                s.setAttribute("defer", "");
                document.head.appendChild(s);
            })();
        </script>
    </head>
    <body>
        <slot />
    </body>
</html>

<script>
    // ── motion-v inView for Astro section reveals ───────────────────────────
    // Uses the same motion library as CtaCard / SkillBubbles, keeping a
    // single unified animation approach across the whole site.
    import { inView, animate } from "motion-v";

    const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    ).matches;

    if (!reduceMotion) {
        inView(
            "[data-reveal]",
            (element) => {
                animate(
                    element,
                    { opacity: [0, 1], y: [24, 0] },
                    { duration: 0.55, ease: [0.22, 1, 0.36, 1] },
                );
            },
            { amount: 0.1 },
        );
    } else {
        // Skip animation for reduced-motion users — just make visible immediately
        document
            .querySelectorAll<HTMLElement>("[data-reveal]")
            .forEach((el) => {
                el.style.opacity = "1";
                el.style.transform = "none";
            });
    }
</script>
