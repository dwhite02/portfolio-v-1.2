---
import "@/scss/main.scss";
import "@/scss/layout.scss";
import "@/tailwind.css";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    noindex?: boolean;
}

const {
    title = "Mind of Tay | Frontend Developer and Digital Designer",
    description = "Portfolio website of Tay, a frontend developer and digital designer showcasing recent projects, UI work, and creative development.",
    image = "/search-music-v2.svg",
    noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL("https://dontewhite.com");
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const imageUrl = new URL(image, site).toString();

const personJsonLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Tay",
    url: canonicalUrl,
    jobTitle: "Frontend Developer and Digital Designer",
    sameAs: [
        "https://github.com/dwhite02",
        "https://www.linkedin.com",
    ],
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@100;300;400;500;700;900&family=Roboto:wght@100;300;400;500;700;900&family=Passion+One:wght@700;900&display=swap"
        />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="portfolio, frontend developer, UI developer, digital designer, Chicago, web development, Vue, Astro"
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#ff3366" />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/svg+xml" href="/vite.svg" />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={imageUrl} />
        <meta property="og:site_name" content="Mind of Tay" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={imageUrl} />

        {noindex && <meta name="robots" content="noindex, nofollow" />}

        <script is:inline type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    </head>
    <body>
        <slot />
    </body>
</html>
