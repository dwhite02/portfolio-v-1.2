---
import { Image } from "astro:assets";
import tayPortrait from "@/assets/tay-3d.png";

const heroImageWidth = 1024;
const heroImageHeight = 1024;
---

<!-- Add this alongside the existing <script> -->
<script>
    import { animate } from "motion-v";

    // ── Skeleton fade-in ──────────────────────────────────────
    const img = document.querySelector(".t-img") as HTMLImageElement | null;
    const inner = document.querySelector(
        ".t-portrait__inner",
    ) as HTMLElement | null;

    function onLoad() {
        img?.classList.add("is-loaded");
        inner?.classList.add("is-loaded");
    }

    if (img) {
        if (img.complete && img.naturalWidth > 0) onLoad();
        else img.addEventListener("load", onLoad, { once: true });
    }

    // ── Auto 3D drift with Motion ─────────────────────────────
    const card = document.getElementById("portrait-card") as HTMLElement | null;
    const glare = document.getElementById(
        "portrait-glare",
    ) as HTMLElement | null;

    if (
        card &&
        glare &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
        // Keyframe sequence — organic non-repeating waypoints
        const keyframes = [
            { rotateX: 5, rotateY: 8, translateZ: 6 },
            { rotateX: -4, rotateY: 14, translateZ: 10 },
            { rotateX: -7, rotateY: 3, translateZ: 4 },
            { rotateX: -3, rotateY: -10, translateZ: 8 },
            { rotateX: 6, rotateY: -14, translateZ: 4 },
            { rotateX: 8, rotateY: -4, translateZ: 10 },
            { rotateX: 3, rotateY: 5, translateZ: 6 },
            { rotateX: 5, rotateY: 8, translateZ: 6 },
        ];

        const times = [0, 0.12, 0.26, 0.42, 0.58, 0.72, 0.88, 1];

        animate(
            card,
            {
                rotateX: keyframes.map(({ rotateX }) => rotateX),
                rotateY: keyframes.map(({ rotateY }) => rotateY),
                translateZ: keyframes.map(({ translateZ }) => translateZ),
            },
            {
                duration: 14,
                repeat: Infinity,
                repeatType: "loop",
                ease: "easeInOut",
                times,
            },
        );

        // Glare follows the tilt via a separate lightweight RAF
        // (Motion doesn't directly animate arbitrary style props like gradients)
        let rafId = 0;

        function syncGlare() {
            if (!glare) {
                return;
            }

            const style = getComputedStyle(card!);
            const matrix = new DOMMatrixReadOnly(style.transform);

            // Extract approximate rotation from the matrix
            const ry = Math.atan2(matrix.m13, matrix.m33) * (180 / Math.PI);
            const rx =
                Math.atan2(
                    -matrix.m23,
                    Math.sqrt(matrix.m21 ** 2 + matrix.m22 ** 2),
                ) *
                (180 / Math.PI);

            const gx = ((ry / 10) * 0.5 + 0.5) * 100;
            const gy = ((rx / 6) * 0.5 + 0.5) * 100;

            glare.style.opacity = "1";
            glare.style.background = `radial-gradient(
                circle at ${gx.toFixed(1)}% ${gy.toFixed(1)}%,
                rgba(255,255,255,0.09) 0%,
                transparent 58%
            )`;

            rafId = requestAnimationFrame(syncGlare);
        }

        rafId = requestAnimationFrame(syncGlare);

        // Pause both when off screen
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((e) => {
                    if (!e.isIntersecting) {
                        cancelAnimationFrame(rafId);
                        rafId = 0;
                    } else if (!rafId) {
                        rafId = requestAnimationFrame(syncGlare);
                    }
                });
            },
            { threshold: 0.1 },
        );

        observer.observe(card);
    }

    // ── Scroll cue ───────────────────────────────────────────
    // const cue = document.getElementById("scroll-cue");
    // cue?.addEventListener("click", () => {
    //     const next = document.querySelector("#home + section") as HTMLElement;
    //     next?.scrollIntoView({ behavior: "smooth" });
    // });
</script>

<section id="home" class="t-view" aria-labelledby="home-title">
    <!-- Architectural grid lines — print-inspired -->
    <div class="t-grid-lines" aria-hidden="true">
        <span class="gl gl--v1"></span>
        <span class="gl gl--v2"></span>
        <span class="gl gl--h1"></span>
    </div>

    <div class="t-blobs" aria-hidden="true">
        <span class="blob b1"></span>
        <span class="blob b2"></span>
        <span class="blob b3"></span>
    </div>

    <!-- Floating decals — restrained, 2 max -->
    <div class="t-decals" aria-hidden="true">
        <span class="decal star"></span>
        <span class="decal cross"></span>
    </div>

    <div class="t-wrapper">
        <!-- Ticker — now at bottom like a news chyron -->
        <div class="t-ticker" aria-hidden="true">
            <span class="t-ticker__label">Now available</span>
            <div class="t-ticker__scroll">
                <div class="t-ticker__track">
                    <span>Frontend Dev</span><span class="sep">✦</span>
                    <span>Digital Design</span><span class="sep">✦</span>
                    <span>UI/UX</span><span class="sep">✦</span>
                    <span>Creative Tech</span><span class="sep">✦</span>
                    <span>React</span><span class="sep">✦</span>
                    <span>Vue</span><span class="sep">✦</span>
                    <span>Astro</span><span class="sep">✦</span>
                    <span>GSAP</span><span class="sep">✦</span>
                    <span>Frontend Dev</span><span class="sep">✦</span>
                    <span>Digital Design</span><span class="sep">✦</span>
                    <span>UI/UX</span><span class="sep">✦</span>
                    <span>Creative Tech</span><span class="sep">✦</span>
                    <span>React</span><span class="sep">✦</span>
                    <span>Vue</span><span class="sep">✦</span>
                    <span>Astro</span><span class="sep">✦</span>
                    <span>GSAP</span><span class="sep">✦</span>
                </div>
            </div>
        </div>

        <div data-reveal class="t-content">
            <!-- Left col: all text -->
            <div class="t-left">
                <div class="t-kicker">
                    <span class="t-kicker__dot" aria-hidden="true"></span>
                    <span>Currently at Radancy</span>
                    <span class="t-kicker__divider" aria-hidden="true"></span>
                    <span>Open to work</span>
                </div>

                <h1
                    id="home-title"
                    class="t-heading"
                    aria-label="Frontend Developer and Designer"
                >
                    <span class="t-heading__word">Mind</span><span
                        class="t-heading__word t-heading__word--accent"
                        >OfTay.</span
                    >
                    <span class="t-heading__sub">Developer &amp; Designer</span>
                </h1>

                <p class="t-tagline">
                    I build bold, interactive web experiences — where design
                    meets code and neither one blinks first.
                </p>

                <div class="t-rule" aria-hidden="true"></div>

                <div class="t-meta">
                    <div class="t-social-links">
                        <a
                            href="https://github.com/dwhite02"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="GitHub"
                        >
                            <span class="t-social-links__label">GitHub</span>
                            <span
                                class="t-social-links__arrow"
                                aria-hidden="true">↗</span
                            >
                        </a>
                        <a
                            href="https://www.linkedin.com/in/dontewhite/"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="LinkedIn"
                        >
                            <span class="t-social-links__label">LinkedIn</span>
                            <span
                                class="t-social-links__arrow"
                                aria-hidden="true">↗</span
                            >
                        </a>
                    </div>

                    <div class="t-chips">
                        <span class="chip chip--lime">React</span>
                        <span class="chip chip--mint">WCAG 2.1</span>
                        <span class="chip chip--coral">UI/UX</span>
                        <span class="chip chip--gold">TypeScript</span>
                        <!-- <span class="chip chip--gold">Astro</span> -->
                    </div>
                </div>
            </div>

            <!-- Right col: portrait editorial treatment -->
            <div class="t-right">
                <!-- Issue / edition label — editorial magazine feel -->
                <div class="t-edition" aria-hidden="true">
                    <span class="t-edition__num">Vol. 01</span>
                    <span class="t-edition__rule"></span>
                    <span class="t-edition__name">Portfolio</span>
                </div>

                <!-- Replace the portrait HTML -->
                <div class="t-portrait" id="portrait-3d">
                    <div class="t-portrait__scene">
                        <div class="t-portrait__card" id="portrait-card">
                            <div class="t-portrait__inner">
                                <Image
                                    class="t-img"
                                    src={tayPortrait}
                                    alt="Portrait of Donte White"
                                    width={heroImageWidth}
                                    height={heroImageHeight}
                                    format="webp"
                                    quality={90}
                                    loading="eager"
                                    fetchpriority="high"
                                    decoding="sync"
                                />
                                <!-- Specular glare layer -->
                                <div
                                    class="t-portrait__glare"
                                    id="portrait-glare"
                                    aria-hidden="true"
                                >
                                </div>
                            </div>
                            <span
                                class="t-portrait__pip t-portrait__pip--tl"
                                aria-hidden="true"></span>
                            <span
                                class="t-portrait__pip t-portrait__pip--br"
                                aria-hidden="true"></span>
                        </div>
                    </div>

                    <div class="t-portrait__caption">
                        <span class="t-portrait__name">Donte White</span>
                        <span class="t-portrait__title"
                            >Frontend Developer &amp; Designer</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- <button
        class="t-scroll-cue"
        aria-label="Scroll to next section"
        id="scroll-cue"
    >
        <span class="t-scroll-cue__line"></span>
        <span class="t-scroll-cue__label">Scroll</span>
    </button> -->
</section>

<style lang="scss">
    @use "../../scss/abstracts" as *;

    /* ─────────────────────────────────────────
       Section
    ───────────────────────────────────────── */
    #home {
        position: relative;
        min-height: 100vh;
        min-height: 100svh;
        background-color: var(--clr-bg);
        color: var(--clr-text);
        overflow: hidden;
        isolation: isolate;
    }

    /* Ambient glow — subtle, not dominant */
    #home::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
            radial-gradient(
                ellipse 70vw 60vh at 100% 0%,
                color-mix(in oklab, var(--clr-primary) 7%, transparent),
                transparent 65%
            ),
            radial-gradient(
                ellipse 50vw 50vh at 0% 100%,
                color-mix(in oklab, var(--clr-secondary) 6%, transparent),
                transparent 65%
            );
    }

    /* ─────────────────────────────────────────
       Blobs
    ───────────────────────────────────────── */

    .t-blobs {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }

    .blob {
        position: absolute;
        border-radius: 999px;
        opacity: 0.07;
    }

    .blob.b1 {
        width: clamp(180px, 28vw, 420px);
        height: clamp(120px, 18vw, 280px);
        background: var(--clr-primary);
        top: 8%;
        left: -4%;
        transform: rotate(-14deg);
        border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    }

    .blob.b2 {
        width: clamp(140px, 22vw, 340px);
        height: clamp(100px, 16vw, 240px);
        background: var(--clr-secondary);
        bottom: 12%;
        right: -2%;
        transform: rotate(10deg);
        border-radius: 45% 55% 40% 60% / 60% 40% 55% 45%;
    }

    .blob.b3 {
        width: clamp(100px, 14vw, 200px);
        height: clamp(100px, 14vw, 200px);
        background: var(--clr-accent-warm);
        top: 55%;
        left: 44%;
        transform: rotate(5deg);
        border-radius: 55% 45% 60% 40% / 45% 55% 40% 60%;
        opacity: 0.05;
    }

    /* ─────────────────────────────────────────
       Architectural grid lines
       Thin vertical/horizontal rules that give
       the layout a print/editorial backbone
    ───────────────────────────────────────── */
    .t-grid-lines {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }

    .gl {
        position: absolute;
        background: var(--clr-border);
        opacity: 0.4;
    }

    // Vertical line — right edge of left column
    .gl--v1 {
        width: 1px;
        top: 0;
        bottom: 0;
        left: 50%;

        @include breakpoint(lg, max) {
            display: none;
        }
    }

    // Short vertical accent near portrait
    .gl--v2 {
        width: 1px;
        height: 120px;
        top: 0;
        right: clamp(80px, 10vw, 160px);
        opacity: 0.2;
    }

    // Horizontal rule — sits above the ticker
    .gl--h1 {
        height: 1px;
        left: 0;
        right: 0;
        bottom: clamp(48px, 8vh, 72px);
        opacity: 0.25;
    }

    /* ─────────────────────────────────────────
       Decals — 2 only, restrained
    ───────────────────────────────────────── */
    .t-decals {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
    }

    @keyframes floaty {
        from {
            transform: translateY(0) rotate(0deg);
        }
        to {
            transform: translateY(-10px) rotate(7deg);
        }
    }

    @keyframes floaty-r {
        from {
            transform: translateY(0) rotate(0deg);
        }
        to {
            transform: translateY(-8px) rotate(-5deg);
        }
    }

    .decal {
        position: absolute;
        display: block;
    }

    .decal.star {
        width: clamp(16px, 2vw, 26px);
        height: clamp(16px, 2vw, 26px);
        background: var(--clr-primary);
        clip-path: polygon(
            50% 0%,
            61% 35%,
            98% 35%,
            68% 57%,
            79% 91%,
            50% 70%,
            21% 91%,
            32% 57%,
            2% 35%,
            39% 35%
        );
        filter: drop-shadow(0 0 8px var(--clr-primary));
        top: 18%;
        right: 18%;
        animation: floaty 4.2s ease-in-out infinite alternate;
    }

    .decal.cross {
        width: clamp(12px, 1.4vw, 18px);
        height: clamp(12px, 1.4vw, 18px);
        background: var(--clr-secondary);
        clip-path: polygon(
            35% 0%,
            65% 0%,
            65% 35%,
            100% 35%,
            100% 65%,
            65% 65%,
            65% 100%,
            35% 100%,
            35% 65%,
            0% 65%,
            0% 35%,
            35% 35%
        );
        filter: drop-shadow(0 0 6px var(--clr-secondary));
        bottom: 28%;
        left: 8%;
        animation: floaty-r 3.8s ease-in-out 0.5s infinite alternate;
    }

    @media (prefers-reduced-motion: reduce) {
        .decal {
            animation: none;
        }
    }

    /* ─────────────────────────────────────────
       Wrapper
    ───────────────────────────────────────── */
    .t-wrapper {
        position: relative;
        z-index: 2;
        width: 100%;
        min-height: 100vh;
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        padding-inline: clamp(24px, 6vw, 96px);
        padding-block: clamp(80px, 10vh, 120px) 0;
    }

    /* ─────────────────────────────────────────
       Content grid
    ───────────────────────────────────────── */
    .t-content {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: auto;
        gap: clamp(40px, 6vw, 80px);
        align-items: center;
        padding-bottom: clamp(80px, 12vh, 120px);

        @include breakpoint(lg) {
            grid-template-columns: 1.1fr 0.9fr;
            gap: 0;
        }
    }

    /* ─────────────────────────────────────────
       Left column
    ───────────────────────────────────────── */
    .t-left {
        display: flex;
        flex-direction: column;
        gap: clamp(20px, 3vw, 32px);
        align-items: flex-start;

        @include breakpoint(lg) {
            padding-right: clamp(40px, 5vw, 80px);
        }
    }

    /* Kicker line — status / availability */
    .t-kicker {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: clamp(0.62rem, 0.9vw, 0.74rem);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--clr-text-dim);

        &__dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--clr-secondary);
            flex-shrink: 0;
            animation: pulse 2.4s ease-in-out infinite;
        }

        &__divider {
            display: inline-block;
            width: 1px;
            height: 12px;
            background: var(--clr-border);
        }
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.4;
            transform: scale(0.65);
        }
    }

    /* ─────────────────────────────────────────
       Main heading — editorial magazine style
       Large display type, asymmetric weight
    ───────────────────────────────────────── */
    .t-heading {
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .t-heading__word {
        display: block;
        font-size: clamp(3.8rem, 10vw, 9rem);
        font-weight: 900;
        line-height: 0.88;
        letter-spacing: -0.04em;
        text-transform: uppercase;
        color: var(--clr-text);

        &--accent {
            color: var(--clr-primary);
            // Cartoon text offset shadow
            text-shadow:
                3px 5px 0
                    color-mix(in oklab, var(--clr-primary) 22%, transparent),
                0 0 60px var(--clr-primary-dim);
            -webkit-text-stroke: 1px
                color-mix(in oklab, var(--clr-primary) 35%, transparent);
        }
    }

    // Smaller subtitle line below the big word
    .t-heading__sub {
        display: block;
        font-size: clamp(0.85rem, 1.6vw, 1.15rem);
        font-weight: 400;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--clr-text-dim);
        margin-top: clamp(10px, 1.5vw, 18px);
        line-height: 1;
    }

    /* ─────────────────────────────────────────
       Tagline
    ───────────────────────────────────────── */
    .t-tagline {
        margin: 0;
        font-size: clamp(0.95rem, 1.5vw, 1.12rem);
        font-weight: 300;
        line-height: 1.7;
        color: var(--clr-text);
        opacity: 0.72;
        max-width: 46ch;
    }

    /* ─────────────────────────────────────────
       Rule — thin print divider
    ───────────────────────────────────────── */
    .t-rule {
        width: 100%;
        height: 1px;
        background: linear-gradient(
            90deg,
            var(--clr-primary) 0%,
            var(--clr-border) 40%,
            transparent 100%
        );
    }

    /* ─────────────────────────────────────────
       Meta row: socials + chips
    ───────────────────────────────────────── */
    .t-meta {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;

        @include breakpoint(md) {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }

    .t-social-links {
        display: flex;
        gap: 20px;

        a {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            color: var(--clr-text-dim);
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-decoration: none;
            text-transform: uppercase;
            transition: color 0.2s ease;

            &:hover {
                color: var(--clr-primary);

                .t-social-links__arrow {
                    transform: translate(2px, -2px);
                }
            }
        }

        &__arrow {
            display: inline-block;
            font-style: normal;
            transition: transform 0.2s ease;
            font-size: 0.9em;
        }
    }

    .t-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 4px 12px;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: 1.5px solid transparent;
        box-shadow: 2px 2px 0 var(--clr-border);
        transition:
            transform 0.15s ease,
            box-shadow 0.15s ease;

        &:hover {
            transform: translateY(-2px);
            box-shadow: 3px 4px 0 var(--clr-border);
        }

        &--lime {
            background: var(--clr-primary-dim);
            color: var(--clr-primary);
            border-color: color-mix(
                in oklab,
                var(--clr-primary) 30%,
                transparent
            );
        }
        &--mint {
            background: var(--clr-secondary-dim);
            color: var(--clr-secondary);
            border-color: color-mix(
                in oklab,
                var(--clr-secondary) 30%,
                transparent
            );
        }
        &--coral {
            background: rgba(255, 107, 89, 0.12);
            color: var(--clr-accent-warm);
            border-color: rgba(255, 107, 89, 0.3);
        }
        &--purple {
            background: rgba(167, 100, 255, 0.12);
            color: var(--clr-accent-purple);
            border-color: rgba(167, 100, 255, 0.3);
        }
        &--gold {
            background: rgba(255, 209, 102, 0.12);
            color: var(--clr-accent-gold);
            border-color: rgba(255, 209, 102, 0.3);
        }
    }

    /* ─────────────────────────────────────────
       Right column — editorial portrait
    ───────────────────────────────────────── */
    .t-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        position: relative;

        @include breakpoint(lg) {
            align-items: flex-end;
            padding-left: clamp(40px, 5vw, 80px);
        }
    }

    /* Vol / edition label — magazine masthead style */
    .t-edition {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        align-self: flex-start;

        @include breakpoint(lg) {
            align-self: flex-end;
        }

        &__num {
            font-size: 0.62rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--clr-text-dim);
        }

        &__rule {
            display: inline-block;
            width: 32px;
            height: 1px;
            background: var(--clr-border);
        }

        &__name {
            font-size: 0.62rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--clr-primary);
        }
    }

    /* Replace the portrait styles */

    .t-portrait {
        display: flex;
        flex-direction: column;
        gap: 0;
        width: min(100%, 360px);

        @include breakpoint(lg) {
            width: min(100%, 400px);
        }
    }

    /* The scene needs more perspective depth for a character */
    .t-portrait__scene {
        perspective: 600px; // tighter perspective = more dramatic depth
        perspective-origin: center 40%; // origin slightly above center so face tilts naturally
        width: 100%;
        padding-right: 20px;
        padding-bottom: 24px;
        box-sizing: border-box;
    }

    .t-portrait__card {
        position: relative;
        width: 100%;
        aspect-ratio: 1 / 1; // square crop for the character head render
