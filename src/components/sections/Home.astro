---
import { Image } from "astro:assets";
import tayPortrait from "@/assets/tay.png";

const heroImageWidth = 461;
const heroImageHeight = 461;
---

<section id="home" class="t-view" aria-labelledby="home-title">
    <div class="t-wrapper">
        <!-- Floating cartoon blobs -->
        <div class="t-blobs" aria-hidden="true">
            <span class="blob b1"></span>
            <span class="blob b2"></span>
            <span class="blob b3"></span>
        </div>

        <!-- Floating decal stars inspired by Seán's ✦ motif -->
        <div class="t-decals" aria-hidden="true">
            <span class="decal star s1"></span>
            <span class="decal star s2"></span>
            <span class="decal cross c1"></span>
        </div>

        <!-- Ticker tape label strip like Seán's project category labels -->
        <div class="t-ticker" aria-hidden="true">
            <div class="t-ticker__track">
                <span>Frontend Dev</span><span aria-hidden="true">✦</span>
                <span>Digital Design</span><span aria-hidden="true">✦</span>
                <span>UI/UX</span><span aria-hidden="true">✦</span>
                <span>Creative Tech</span><span aria-hidden="true">✦</span>
                <span>Frontend Dev</span><span aria-hidden="true">✦</span>
                <span>Digital Design</span><span aria-hidden="true">✦</span>
                <span>UI/UX</span><span aria-hidden="true">✦</span>
                <span>Creative Tech</span><span aria-hidden="true">✦</span>
            </div>
        </div>

        <div class="t-content">
            <!-- Left: text stack -->
            <div class="t-title-group">
                <p class="t-eyebrow">Currently at Radancy</p>

                <h1 id="home-title" class="t-heading">
                    <span class="t-heading__line">Frontend</span>
                    <span class="t-heading__line accent">Developer</span>
                    <span class="t-heading__line">&amp; Designer.</span>
                </h1>

                <p class="t-tagline">
                    I build bold, interactive web experiences.
                </p>

                <div class="t-hero-meta">
                    <span class="t-badge">
                        <span class="t-badge__dot" aria-hidden="true"></span>
                        Open to work
                    </span>
                    <div class="t-social-links">
                        <a
                            href="https://github.com/dwhite02"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="GitHub">GitHub</a
                        >
                        <a
                            href="https://www.linkedin.com/in/dontewhite/"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="LinkedIn">LinkedIn</a
                        >
                    </div>
                </div>

                <!-- Pill chip row — inspired by Seán's project category labels -->
                <div class="t-chips" aria-label="Specialties">
                    <span class="chip chip--lime">React</span>
                    <span class="chip chip--mint">Vue</span>
                    <span class="chip chip--coral">Figma</span>
                    <span class="chip chip--purple">GSAP</span>
                    <span class="chip chip--gold">Astro</span>
                </div>
            </div>

            <!-- Right: portrait in cartoon card frame -->
            <div class="t-image">
                <!-- Comic-style corner label like Seán's "HELP SCOUT / AI" -->
                <div class="t-card-label" aria-hidden="true">
                    <span class="t-card-label__super">PORTFOLIO</span>
                    <span class="t-card-label__main">Donte.</span>
                </div>

                <div class="t-frame">
                    <div class="t-frame__inner">
                        <Image
                            class="t-img"
                            src={tayPortrait}
                            alt="Portrait"
                            width={heroImageWidth}
                            height={heroImageHeight}
                            format="webp"
                            quality={90}
                            loading="eager"
                            fetchpriority="high"
                        />
                    </div>
                    <!-- Cartoon corner notch accent -->
                    <span class="t-frame__notch" aria-hidden="true"></span>
                </div>
            </div>
        </div>

        <!-- Bottom scroll cue -->
        <!-- <button
            class="t-scroll-cue"
            aria-label="Scroll to next section"
            id="scroll-cue"
        >
            <span class="t-scroll-cue__line"></span>
            <span class="t-scroll-cue__label">Scroll</span>
        </button> -->
    </div>
</section>

<style lang="scss">
    @use "../../scss/abstracts" as *;

    /* ─────────────────────────────────────────
       Section shell
    ───────────────────────────────────────── */
    #home {
        position: relative;
        min-height: 100vh;
        min-height: 100svh;
        background-color: var(--clr-bg);
        color: var(--clr-text);
        overflow: hidden;
        isolation: isolate;
    }

    /* Subtle radial glow pools — like Seán's ambient background depth */
    #home::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
            radial-gradient(
                ellipse 60vw 50vh at 15% 20%,
                color-mix(in oklab, var(--clr-primary) 10%, transparent),
                transparent 70%
            ),
            radial-gradient(
                ellipse 50vw 40vh at 85% 75%,
                color-mix(in oklab, var(--clr-secondary) 10%, transparent),
                transparent 70%
            ),
            radial-gradient(
                ellipse 40vw 30vh at 60% 10%,
                color-mix(in oklab, var(--clr-accent-purple) 7%, transparent),
                transparent 70%
            );
    }

    /* ─────────────────────────────────────────
       Wrapper
    ───────────────────────────────────────── */
    .t-wrapper {
        position: relative;
        z-index: 1;
        width: 100%;
        min-height: inherit;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding-inline: clamp(20px, 5vw, 80px);
        padding-block: clamp(100px, 12vh, 140px) clamp(60px, 8vh, 100px);
        gap: clamp(32px, 5vh, 56px);
    }

    /* ─────────────────────────────────────────
       Cartoon blobs — big rounded shapes
       inspired by Seán's pastel project cards
    ───────────────────────────────────────── */
    .t-blobs {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }

    .blob {
        position: absolute;
        border-radius: 999px;
        opacity: 0.07;
        filter: blur(0px);
    }

    .blob.b1 {
        width: clamp(180px, 28vw, 420px);
        height: clamp(120px, 18vw, 280px);
        background: var(--clr-primary);
        top: 8%;
        left: -4%;
        transform: rotate(-14deg);
        border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    }

    .blob.b2 {
        width: clamp(140px, 22vw, 340px);
        height: clamp(100px, 16vw, 240px);
        background: var(--clr-secondary);
        bottom: 12%;
        right: -2%;
        transform: rotate(10deg);
        border-radius: 45% 55% 40% 60% / 60% 40% 55% 45%;
    }

    .blob.b3 {
        width: clamp(100px, 14vw, 200px);
        height: clamp(100px, 14vw, 200px);
        background: var(--clr-accent-warm);
        top: 55%;
        left: 44%;
        transform: rotate(5deg);
        border-radius: 55% 45% 60% 40% / 45% 55% 40% 60%;
        opacity: 0.05;
    }

    /* ─────────────────────────────────────────
       Decals — ✦ star / cross motifs
    ───────────────────────────────────────── */
    .t-decals {
        position: absolute;
        inset: 0;
        z-index: 2;
        pointer-events: none;
    }

    @keyframes floaty {
        from {
            transform: translateY(0) rotate(0deg);
        }
        to {
            transform: translateY(-12px) rotate(8deg);
        }
    }

    @keyframes floaty-r {
        from {
            transform: translateY(0) rotate(0deg);
        }
        to {
            transform: translateY(-8px) rotate(-6deg);
        }
    }

    .decal {
        position: absolute;
        display: block;
        animation: floaty 4s ease-in-out infinite alternate;
    }

    .decal.star {
        width: clamp(18px, 2.2vw, 30px);
        height: clamp(18px, 2.2vw, 30px);
        background: var(--clr-primary);
        clip-path: polygon(
            50% 0%,
            61% 35%,
            98% 35%,
            68% 57%,
            79% 91%,
            50% 70%,
            21% 91%,
            32% 57%,
            2% 35%,
            39% 35%
        );
        filter: drop-shadow(0 0 8px var(--clr-primary));
    }

    .decal.cross {
        width: clamp(14px, 1.6vw, 22px);
        height: clamp(14px, 1.6vw, 22px);
        background: var(--clr-secondary);
        clip-path: polygon(
            35% 0%,
            65% 0%,
            65% 35%,
            100% 35%,
            100% 65%,
            65% 65%,
            65% 100%,
            35% 100%,
            35% 65%,
            0% 65%,
            0% 35%,
            35% 35%
        );
        filter: drop-shadow(0 0 6px var(--clr-secondary));
        animation-name: floaty-r;
    }

    .decal.s1 {
        top: 14%;
        right: 38%;
        animation-duration: 3.6s;
    }
    .decal.s2 {
        bottom: 22%;
        left: 10%;
        animation-duration: 4.4s;
        animation-delay: 0.8s;
    }
    .decal.c1 {
        top: 38%;
        right: 10%;
        animation-duration: 3.2s;
        animation-delay: 0.4s;
    }

    @media (prefers-reduced-motion: reduce) {
        .decal {
            animation: none;
        }
    }

    /* ─────────────────────────────────────────
       Ticker tape strip
       Inspired by Seán's "In Progress." section
       and project category label strips
    ───────────────────────────────────────── */
    .t-ticker {
        width: calc(100% + 160px);
        overflow: hidden;
        background: var(--clr-primary);
        color: var(--clr-header-text);
        padding-block: 7px;
        position: absolute;
        top: clamp(60px, 9vh, 88px);
        left: -80px;
        transform: rotate(-1.5deg);
        z-index: 3;
        border-top: 2px solid var(--clr-header-text);
        border-bottom: 2px solid var(--clr-header-text);
    }

    @keyframes ticker {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    .t-ticker__track {
        display: flex;
        gap: clamp(20px, 4vw, 40px);
        width: max-content;
        animation: ticker 18s linear infinite;
        font-size: clamp(0.65rem, 1vw, 0.78rem);
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        white-space: nowrap;
        padding-inline: 20px;

        span {
            flex-shrink: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .t-ticker__track {
            animation: none;
        }
    }

    /* ─────────────────────────────────────────
       Main content grid
    ───────────────────────────────────────── */
    .t-content {
        position: relative;
        z-index: 4;
        width: 100%;
        max-width: 1400px;
        display: grid;
        grid-template-areas: "art" "title";
        gap: clamp(32px, 5vw, 64px);
        align-items: center;
        justify-items: center;
        margin-top: clamp(48px, 8vh, 80px);

        @include breakpoint(lg) {
            grid-template-columns: 1fr 1fr;
            grid-template-areas: "title art";
            justify-items: start;
        }
    }

    /* ─────────────────────────────────────────
       Left: text group
    ───────────────────────────────────────── */
    .t-title-group {
        grid-area: title;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: clamp(12px, 2vw, 20px);
        width: 100%;

        @include breakpoint(lg) {
            align-items: flex-start;
        }
    }

    .t-eyebrow {
        font-size: clamp(0.65rem, 1vw, 0.78rem);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--clr-text-dim);
        margin: 0;
    }

    /* Seán-inspired large display heading — each line gets its own feel */
    .t-heading {
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
        text-align: center;

        @include breakpoint(lg) {
            text-align: left;
        }
    }

    .t-heading__line {
        display: block;
        font-size: clamp(2.6rem, 7vw, 6.5rem);
        font-weight: 900;
        line-height: 0.95;
        letter-spacing: -0.03em;
        color: var(--clr-text);
        text-transform: uppercase;

        // The accent line pops with primary lime — like Seán's mint heading
        &.accent {
            color: var(--clr-primary);
            text-shadow:
                0 0 48px var(--clr-primary-dim),
                2px 4px 0 var(--clr-bg-elev);
            // Cartoon outline effect
            -webkit-text-stroke: 1.5px
                color-mix(in oklab, var(--clr-primary) 40%, transparent);
        }
    }

    .t-tagline {
        margin: 0;
        font-size: clamp(0.9rem, 1.6vw, 1.15rem);
        font-weight: 300;
        color: var(--clr-text);
        opacity: 0.75;
        text-align: center;

        @include breakpoint(lg) {
            text-align: left;
        }
    }

    /* ─────────────────────────────────────────
       Badge + social
    ───────────────────────────────────────── */
    .t-hero-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: clamp(10px, 2vw, 18px);
        justify-content: center;

        @include breakpoint(lg) {
            justify-content: flex-start;
        }
    }

    @keyframes badge-pulse {
        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.45;
            transform: scale(0.7);
        }
    }

    .t-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        color: var(--clr-text);
        border: 1.5px solid var(--clr-secondary-dim);
        border-radius: 999px;
        padding: 5px 14px;
        background: var(--clr-secondary-dim);
        white-space: nowrap;

        &__dot {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--clr-secondary);
            flex-shrink: 0;
            animation: badge-pulse 2.2s ease-in-out infinite;
        }
    }

    .t-social-links {
        display: inline-flex;
        align-items: center;

        a {
            color: var(--clr-text-dim);
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-decoration: none;
            text-transform: uppercase;
            transition: color 0.2s ease;
            padding: 4px 2px;

            &:hover {
                color: var(--clr-primary);
            }
        }

        a + a::before {
            content: "|";
            margin-inline: 8px;
            color: var(--clr-border);
            font-weight: 300;
        }
    }

    /* ─────────────────────────────────────────
       Chips — inspired by Seán's project
       category label pills
    ───────────────────────────────────────── */
    .t-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;

        @include breakpoint(lg) {
            justify-content: flex-start;
        }
    }

    .chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 5px 14px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: 1.5px solid transparent;
        // Slight cartoon outline feel
        box-shadow: 2px 3px 0 var(--clr-border);
        transition:
            transform 0.15s ease,
            box-shadow 0.15s ease;

        &:hover {
            transform: translateY(-2px);
            box-shadow: 3px 5px 0 var(--clr-border);
        }

        &--lime {
            background: var(--clr-primary-dim);
            color: var(--clr-primary);
            border-color: color-mix(
                in oklab,
                var(--clr-primary) 30%,
                transparent
            );
        }
        &--mint {
            background: var(--clr-secondary-dim);
            color: var(--clr-secondary);
            border-color: color-mix(
                in oklab,
                var(--clr-secondary) 30%,
                transparent
            );
        }
        &--coral {
            background: rgba(255, 107, 89, 0.12);
            color: var(--clr-accent-warm);
            border-color: rgba(255, 107, 89, 0.3);
        }
        &--purple {
            background: rgba(167, 100, 255, 0.12);
            color: var(--clr-accent-purple);
            border-color: rgba(167, 100, 255, 0.3);
        }
        &--gold {
            background: rgba(255, 209, 102, 0.12);
            color: var(--clr-accent-gold);
            border-color: rgba(255, 209, 102, 0.3);
        }
    }

    /* ─────────────────────────────────────────
       Right: portrait card
       Inspired by Seán's project cards with
       the small category label at top-right
    ───────────────────────────────────────── */
    .t-image {
        grid-area: art;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
    }

    /* Comic card label — mirrors Seán's "HELP SCOUT / AI" label in cards */
    .t-card-label {
        position: absolute;
        top: -14px;
        right: clamp(16px, 6%, 40px);
        z-index: 5;
        background: var(--clr-surface);
        border: 1.5px solid var(--clr-border);
        border-radius: 10px;
        padding: 6px 14px 8px;
        text-align: right;
        box-shadow: 3px 4px 0 var(--clr-border);

        &__super {
            display: block;
            font-size: 0.58rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--clr-text-dim);
        }

        &__main {
            display: block;
            font-size: clamp(1.1rem, 2.2vw, 1.5rem);
            font-weight: 900;
            letter-spacing: -0.02em;
            color: var(--clr-text);
            line-height: 1;
        }
    }

    /* Frame — cartoon outline style with offset shadow like Seán's cards */
    .t-frame {
        position: relative;
        width: min(100%, 420px);
        border-radius: 28px;
        background: var(--clr-surface);
        border: 2.5px solid var(--clr-border);
        // Cartoon offset box shadow — the key "explorer cartoon" touch
        box-shadow:
            6px 8px 0 var(--clr-primary),
            12px 16px 0 var(--clr-border);
        overflow: visible;
        padding: clamp(10px, 2vw, 16px);
        transition:
            transform 0.25s ease,
            box-shadow 0.25s ease;

        &:hover {
            transform: translate(-3px, -3px);
            box-shadow:
                9px 11px 0 var(--clr-primary),
                15px 19px 0 var(--clr-border);
        }

        // Corner accent — the pinstripe notch Seán uses on frames
        &__notch {
            position: absolute;
            bottom: 18px;
            left: -12px;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--clr-secondary);
            border: 2.5px solid var(--clr-border);
            box-shadow: 2px 2px 0 var(--clr-border);
        }
    }

    .t-frame__inner {
        border-radius: 18px;
        overflow: hidden;
        background: var(--clr-card-bg);
        border: 1.5px solid var(--clr-border);
    }

    .t-img {
        display: block;
        width: 100%;
        height: auto;
        object-fit: cover;
    }

    /* ─────────────────────────────────────────
       Scroll cue
    ───────────────────────────────────────── */
    @keyframes scroll-bob {
        0%,
        100% {
            transform: scaleY(1);
            opacity: 0.5;
        }
        50% {
            transform: scaleY(1.5);
            opacity: 1;
        }
    }

    .t-scroll-cue {
        position: relative;
        z-index: 4;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        background: none;
        border: none;
        padding: 8px 12px;
        border-radius: 999px;
        transition: transform 0.2s ease;

        &:hover {
            transform: translateY(3px);

            .t-scroll-cue__line {
                background: var(--clr-secondary);
                box-shadow: 0 0 8px var(--clr-secondary-dim);
            }

            .t-scroll-cue__label {
                color: var(--clr-secondary);
            }
        }

        &:active {
            transform: translateY(5px);
        }

        &:focus-visible {
            outline: 2px solid var(--clr-primary);
            outline-offset: 4px;
        }
    }

    .t-scroll-cue__line {
        display: block;
        width: 1.5px;
        height: 36px;
        background: var(--clr-primary);
        transform-origin: top;
        animation: scroll-bob 2s ease-in-out infinite;
    }

    .t-scroll-cue__label {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--clr-text-dim);
    }

    @media (prefers-reduced-motion: reduce) {
        .t-scroll-cue__line {
            animation: none;
        }
        .t-badge__dot {
            animation: none;
        }
    }
</style>
