---
import ellipse from "@/assets/elipse.svg";
import brain from "@/assets/brain.svg";
import SkillBubbles from "@/components/vue/SkillBubbles.vue";

const jobs = [
    { id: 0, org: "Radancy", role: "Frontend Engineer", date: "MAR21 ~" },
    {
        id: 1,
        org: "Self-Employed",
        role: "Freelance Frontend Engineer",
        date: "DEC20 - AUG24",
    },
    {
        id: 2,
        org: "Neon One",
        role: "Junior Web Designer",
        date: "OCT18 - JUL20",
    },
];

const resumeUrl = "/resume.pdf";
---

<section id="about" class="t-view">
    <div class="t-ambient" aria-hidden="true"></div>

    <div class="t-decals" aria-hidden="true">
        <span class="decal star s1"></span>
        <span class="decal star s2"></span>
        <span class="decal cross c1"></span>
    </div>

    <div class="t-wrapper flex flex-col">
        <div class="t-content">
            <div data-reveal class="t-image p-2">
                <img
                    class="mx-auto"
                    src={ellipse.src}
                    alt="Ellipse graphic"
                    width={ellipse.width}
                    height={ellipse.height}
                    loading="lazy"
                    decoding="async"
                />
            </div>
            <div data-reveal class="t-info p-2">
                <p class="t-eyebrow">Who I am</p>
                <h2 class="t-title">ABOUT</h2>
                <div class="t-text-container text-center md:text-left mx-auto">
                    <p class="t-text">
                        Hey there! Welcome to what you could call my mind,
                        pretty wild, right? But let's skip the tour and get to
                        the good stuff. I'm a digital designer with a passion
                        for blending design and front-end development. I'm
                        always exploring new ways to merge creativity with tech,
                        adding my own twist along the way. If you're here to
                        look around, feel free to treat this like a chill
                        screensaver. And don't worry, you're not actually
                        trapped in here (probably). I've got to prep for my trip
                        to Mars... or was it Mercury? Either way, thanks for
                        stopping by. Who knows, maybe we'll cross paths again in
                        the digital cosmos.
                    </p>
                </div>
            </div>
        </div>

        <!-- ── Skills ── -->
        <div class="t-skills-section">
            <div class="t-skills-header">
                <p class="t-skills-eyebrow">What I work with</p>
                <h3 class="t-skills-heading">TOOLS &amp; TECH</h3>
                <p class="t-skills-hint">Select a category to explore</p>
            </div>
            <SkillBubbles data-reveal client:visible />
        </div>

        <!-- ── Resume — Seán-style "In Progress." large heading + cards ── -->
        <div class="t-resume-section">
            <div class="t-resume-header">
                <p class="t-eyebrow">Where I've been</p>
                <h3 class="t-resume-heading">
                    <span>Experience.</span>
                </h3>
            </div>

            <!-- Job cards in a Seán-style grid -->
            <div class="t-jobs" data-reveal>
                {
                    jobs.map((job, i) => (
                        <div class="t-job-card" data-reveal-child>
                            <div class="t-job-card__label">
                                <span class="t-job-card__super">
                                    {job.date}
                                </span>
                                <span class="t-job-card__index">0{i + 1}</span>
                            </div>
                            <div class="t-job-card__body">
                                <h4 class="t-job-card__org">{job.org}</h4>
                                <p class="t-job-card__role">{job.role}</p>
                            </div>
                        </div>
                    ))
                }
            </div>

            <div class="t-actions">
                <a
                    class="t-btn t-btn--primary"
                    href={resumeUrl}
                    download
                    aria-label="Download full resume PDF"
                >
                    Download Full Resume
                </a>
            </div>
        </div>
    </div>

    <!-- BG decoration -->
    <div class="t-bg">
        <div class="t-brain one">
            <img
                src={brain.src}
                alt=""
                width={brain.width}
                height={brain.height}
                loading="lazy"
                decoding="async"
            />
        </div>
        <div class="t-brain two">
            <img
                src={brain.src}
                alt=""
                width={brain.width}
                height={brain.height}
                loading="lazy"
                decoding="async"
            />
        </div>
    </div>
</section>

<style lang="scss">
    @use "../../scss/abstracts" as *;

    /* ─────────────────────────────────────────
       Section
    ───────────────────────────────────────── */
    .t-view {
        position: relative;
        background-color: var(--clr-bg);
        color: var(--clr-text);
        overflow: hidden;
        isolation: isolate;
    }

    .t-ambient {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
            radial-gradient(
                ellipse 55vw 45vh at 5% 15%,
                color-mix(in oklab, var(--clr-secondary) 8%, transparent),
                transparent 70%
            ),
            radial-gradient(
                ellipse 45vw 35vh at 95% 65%,
                color-mix(in oklab, var(--clr-primary) 7%, transparent),
                transparent 70%
            );
    }

    /* ─────────────────────────────────────────
       Decals
    ───────────────────────────────────────── */
    @keyframes floaty {
        from {
            transform: translateY(0) rotate(0deg);
        }
        to {
            transform: translateY(-10px) rotate(8deg);
        }
    }
    @keyframes floaty-r {
        from {
            transform: translateY(0) rotate(0deg);
        }
        to {
            transform: translateY(-7px) rotate(-6deg);
        }
    }

    .t-decals {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
    }

    .decal {
        position: absolute;
        display: block;
        animation: floaty 4s ease-in-out infinite alternate;
    }

    .decal.star {
        width: clamp(12px, 1.6vw, 22px);
        height: clamp(12px, 1.6vw, 22px);
        background: var(--clr-primary);
        clip-path: polygon(
            50% 0%,
            61% 35%,
            98% 35%,
            68% 57%,
            79% 91%,
            50% 70%,
            21% 91%,
            32% 57%,
            2% 35%,
            39% 35%
        );
        filter: drop-shadow(0 0 6px var(--clr-primary));
    }

    .decal.cross {
        width: clamp(10px, 1.2vw, 18px);
        height: clamp(10px, 1.2vw, 18px);
        background: var(--clr-secondary);
        clip-path: polygon(
            35% 0%,
            65% 0%,
            65% 35%,
            100% 35%,
            100% 65%,
            65% 65%,
            65% 100%,
            35% 100%,
            35% 65%,
            0% 65%,
            0% 35%,
            35% 35%
        );
        filter: drop-shadow(0 0 5px var(--clr-secondary));
        animation-name: floaty-r;
    }

    .decal.s1 {
        top: 8%;
        left: 4%;
        animation-duration: 3.8s;
    }
    .decal.s2 {
        bottom: 30%;
        right: 4%;
        animation-duration: 4.6s;
        animation-delay: 0.5s;
    }
    .decal.c1 {
        top: 48%;
        right: 6%;
        animation-duration: 3.4s;
        animation-delay: 0.3s;
    }

    @media (prefers-reduced-motion: reduce) {
        .decal {
            animation: none;
        }
    }

    /* ─────────────────────────────────────────
       Wrapper
    ───────────────────────────────────────── */
    .t-wrapper {
        position: relative;
        z-index: 2;
        padding-top: clamp(80px, 12vh, 120px);
        gap: clamp(4rem, 8vw, 7rem);
    }

    /* ─────────────────────────────────────────
       Brains
    ───────────────────────────────────────── */
    .t-brain {
        position: absolute;
        filter: drop-shadow(0 0 18px var(--clr-secondary-dim));

        &.one {
            right: 38%;
            bottom: 15%;
            width: 20%;
            display: none;

            @include breakpoint(xl) {
                width: 25%;
                display: block;
                scale: 0.1;
            }
        }

        &.two {
            right: 5%;
            width: 12%;
            top: 0;
            @include breakpoint(md) {
                top: 6%;
            }
        }
    }

    /* ─────────────────────────────────────────
       Eyebrow — reused across sections
    ───────────────────────────────────────── */
    .t-eyebrow {
        font-size: clamp(0.6rem, 1vw, 0.72rem);
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--clr-text-dim);
        margin: 0 0 6px;
    }

    .t-text {
        color: var(--clr-text);
        opacity: 0.9;
    }

    .t-text-container {
        position: relative;
        background-color: var(--clr-surface);
        padding: 20px 24px;
        border: 2.5px solid var(--clr-primary);
        border-radius: 28px;
        height: auto;
        margin-top: 3%;
        max-width: $container-md;
        box-shadow:
            5px 6px 0 color-mix(in oklab, var(--clr-primary) 22%, transparent),
            0 8px 24px var(--clr-shadow);

        &::after {
            display: none;
            position: absolute;
            content: "";
            height: 100%;
            width: 100%;
            right: 0;
            bottom: 0;
            z-index: -1;
            border: 2.5px solid var(--clr-border);
            border-radius: 28px;
            top: 20%;
            left: 10%;

            @include breakpoint(xl) {
                display: block;
            }
        }
    }

    /* ─────────────────────────────────────────
       Hero content grid — original layout
    ───────────────────────────────────────── */
    .t-content {
        max-width: $container-lg;
        margin-inline: auto;
    }

    .t-image {
        margin-left: 0;
        grid-column: 1;
        grid-row: 1;
        align-self: start;
        filter: drop-shadow(0 0 32px var(--clr-secondary-dim));

        @include breakpoint(xl, max) {
            width: 100%;
        }
        @include breakpoint(xl) {
            margin-left: 4%;
        }
    }

    .t-info {
        position: relative;
        color: var(--clr-text);
        grid-column: 1;
        grid-row: 1;
        z-index: 1;
        align-self: center;
        transform: translateY(clamp(-5rem, -18vw, -1.5rem));

        @include breakpoint(xl, max) {
            width: 100%;
        }

        @include breakpoint(xl) {
            grid-column: 2;
            transform: translateY(clamp(-3rem, -6vw, -1rem));
        }
    }

    /* ─────────────────────────────────────────
       Skills
    ───────────────────────────────────────── */
    .t-skills-section {
        width: 100%;
        max-width: $container-base;
        margin-inline: auto;
        padding-inline: clamp(1rem, 4vw, 2rem);
    }

    .t-skills-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        margin-bottom: clamp(1rem, 2.5vw, 1.75rem);

        @include breakpoint(md) {
            align-items: flex-start;
        }
    }

    .t-skills-eyebrow {
        font-size: clamp(0.6rem, 1vw, 0.7rem);
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--clr-text-dim);
        margin: 0;
        text-align: center;
        @include breakpoint(md) {
            text-align: left;
        }
    }

    .t-skills-heading {
        color: var(--clr-text);
        font-size: clamp(1.1rem, 2.5vw, 1.5rem);
        font-weight: 900;
        letter-spacing: 0.12em;
        text-align: center;
        text-transform: uppercase;
        margin: 0;
        text-shadow: 2px 3px 0
            color-mix(in oklab, var(--clr-secondary) 20%, transparent);
        @include breakpoint(md) {
            text-align: left;
        }
    }

    .t-skills-hint {
        color: var(--clr-text-dim);
        font-size: clamp(0.65rem, 1vw, 0.75rem);
        letter-spacing: 0.05em;
        margin: 0;
        text-align: center;
        @include breakpoint(md) {
            text-align: left;
        }
    }

    /* ─────────────────────────────────────────
       Resume — Seán "In Progress." style
    ───────────────────────────────────────── */
    .t-resume-section {
        width: 100%;
        max-width: $container-base;
        margin-inline: auto;
        padding-inline: clamp(1rem, 4vw, 2rem);
        display: flex;
        flex-direction: column;
        gap: clamp(2rem, 4vw, 3rem);
    }

    .t-resume-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;

        @include breakpoint(md) {
            align-items: flex-start;
            text-align: left;
        }
    }

    /* Large "In Progress." style heading */
    .t-resume-heading {
        margin: 0;
        font-size: clamp(2.5rem, 7vw, 6rem);
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 0.95;
        color: var(--clr-text);
        text-shadow: 2px 3px 0
            color-mix(in oklab, var(--clr-secondary) 20%, transparent);

        span {
            display: inline-block;
        }
    }

    /* Job cards — Seán's project card style */
    .t-jobs {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;

        @include breakpoint(md) {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .t-job-card {
        position: relative;
        border-radius: 20px;
        border: 1.5px solid var(--clr-border);
        background: var(--clr-card-bg);
        overflow: hidden;
        padding: 0;
        box-shadow:
            4px 5px 0 color-mix(in oklab, var(--clr-primary) 20%, transparent),
            0 4px 16px var(--clr-shadow);
        transition:
            transform 0.18s ease,
            box-shadow 0.18s ease;

        &:hover {
            transform: translate(-2px, -2px);
            box-shadow:
                6px 7px 0
                    color-mix(in oklab, var(--clr-primary) 28%, transparent),
                0 8px 24px var(--clr-shadow);
        }

        // Gradient top accent — matches the card component
        &::before {
            content: "";
            display: block;
            height: 3px;
            background: linear-gradient(
                90deg,
                var(--clr-secondary),
                var(--clr-primary)
            );
        }

        &__label {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding: 12px 18px 8px;
            border-bottom: 1px solid var(--clr-border);
            background: color-mix(
                in oklab,
                var(--clr-surface) 80%,
                transparent
            );
        }

        &__super {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--clr-text-dim);
        }

        &__index {
            font-size: clamp(1.2rem, 2.5vw, 1.8rem);
            font-weight: 900;
            letter-spacing: -0.04em;
            color: color-mix(in oklab, var(--clr-primary) 22%, transparent);
            line-height: 1;
        }

        &__body {
            padding: 16px 18px 20px;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        &__org {
            font-size: clamp(0.95rem, 1.5vw, 1.1rem);
            font-weight: 800;
            color: var(--clr-primary);
            text-shadow: 0 0 16px var(--clr-primary-dim);
            margin: 0;
            letter-spacing: -0.01em;
        }

        &__role {
            font-size: clamp(0.78rem, 1.2vw, 0.9rem);
            color: var(--clr-text-dim);
            margin: 0;
        }
    }

    /* ─────────────────────────────────────────
       Actions
    ───────────────────────────────────────── */
    .t-actions {
        display: flex;
        justify-content: center;
        padding-inline: 1rem;
        margin-bottom: 10%;

        @include breakpoint(md) {
            justify-content: flex-start;
        }
    }

    .t-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 999px;
        padding: 0.9rem 2rem;
        border: none;
        outline: none;
        transition:
            transform 0.15s ease,
            box-shadow 0.15s ease,
            filter 0.15s ease;

        &--primary {
            background: linear-gradient(
                110deg,
                var(--clr-secondary),
                var(--clr-primary)
            );
            color: var(--clr-header-text);
            box-shadow:
                4px 4px 0 color-mix(in oklab, var(--clr-primary) 40%, black),
                0 8px 20px var(--clr-shadow);

            &:hover {
                transform: translate(-2px, -2px);
                box-shadow:
                    6px 6px 0 color-mix(in oklab, var(--clr-primary) 40%, black),
                    0 12px 28px var(--clr-shadow),
                    0 0 24px var(--clr-primary-dim);
                filter: brightness(1.08);
            }

            &:active {
                transform: translate(1px, 1px);
                box-shadow: 2px 2px 0
                    color-mix(in oklab, var(--clr-primary) 40%, black);
            }

            &:focus-visible {
                outline: 2px solid var(--clr-primary);
                outline-offset: 4px;
            }
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .t-btn,
        .t-job-card {
            transition: none;
        }
        .decal {
            animation: none;
        }
    }
</style>
